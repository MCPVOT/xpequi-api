{
  "name": "pequi-mcp-server",
  "version": "0.3.1",
  "description": "MCP server for Pequi \u2014 Colombia's first real estate data API. Search properties, lookup neighborhoods, get price benchmarks, and geocode addresses in Ibagu\u00e9.",
  "author": "Pequi (xpequi.xyz)",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pequi-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "tsc",
    "prepublish": "npm run build",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "colombia",
    "real-estate",
    "real-estate-api",
    "ibague",
    "bogota",
    "propiedades",
    "inmobiliario",
    "pequi",
    "llama",
    "open-source",
    "open-finance",
    "ai-agents",
    "claude",
    "cursor",
    "chatgpt"
  ],
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@modelcontextprotocol/sdk": "^1.13.0",
    "hono": "4.12.26",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MCPVOT/xpequi-api.git",
    "directory": "packages/mcp-server"
  },
  "publishConfig": {
    "access": "public"
  }
}