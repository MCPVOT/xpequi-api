{
    "name":  "@MCPVOT/mcp-server",
    "version":  "0.2.0",
    "description":  "MCP server for Pequi — Colombia\u0027s first real estate data API. Search properties, lookup neighborhoods, get price benchmarks, and geocode addresses in Ibagué.",
    "author":  "Pequi (xpequi.xyz)",
    "license":  "MIT",
    "type":  "module",
    "bin":  {
                "pequi-mcp":  "./dist/index.js"
            },
    "main":  "./dist/index.js",
    "types":  "./dist/index.d.ts",
    "files":  [
                  "dist/"
              ],
    "scripts":  {
                    "build":  "tsc",
                    "prepublish":  "npm run build",
                    "dev":  "tsx watch src/index.ts",
                    "start":  "node dist/index.js",
                    "inspect":  "npx @modelcontextprotocol/inspector node dist/index.js"
                },
    "keywords":  [
                     "mcp",
                     "model-context-protocol",
                     "colombia",
                     "real-estate",
                     "real-estate-api",
                     "ibague",
                     "bogota",
                     "propiedades",
                     "inmobiliario",
                     "pequi",
                     "llama",
                     "open-source",
                     "open-finance",
                     "ai-agents",
                     "claude",
                     "cursor",
                     "chatgpt"
                 ],
    "dependencies":  {
                         "@modelcontextprotocol/sdk":  "^1.13.0",
                         "zod":  "^3.24.0"
                     },
    "devDependencies":  {
                            "typescript":  "^5.8.0",
                            "tsx":  "^4.22.2",
                            "@types/node":  "^22.0.0"
                        },
    "repository":  {
                       "type":  "git",
                       "url":  "https://github.com/MCPVOT/xpequi-api.git",
                       "directory":  "packages/mcp-server"
                   }
}
