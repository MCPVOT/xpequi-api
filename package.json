{
  "name": "xpequi-api",
  "version": "0.3.1",
  "private": true,
  "description": "Colombia's first real estate data API — search properties, neighborhoods, price benchmarks, geocoding, contracts, payments, and MCP server for AI agents",
  "keywords": ["colombia", "real-estate", "ibague", "bogota", "propiedades", "inmobiliario", "api", "mcp", "real-estate-api", "colombia-real-estate", "open-finance", "c402", "http-402", "prepaid-credits", "uvr", "ipc", "llama", "open-source"],
  "workspaces": [
    "packages/api-client",
    "packages/mcp-server"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "build:client": "npm run build -w packages/api-client",
    "build:mcp": "npm run build -w packages/mcp-server",
    "start:mcp": "npm run start -w packages/mcp-server"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MCPVOT/xpequi-api.git"
  },
  "homepage": "https://xpequi.xyz/developers",
